rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ═══════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasUserIdField() {
      return resource.data.userId == request.auth.uid;
    }

    // ═══════════════════════════════════════════════
    //  USERS
    // ═══════════════════════════════════════════════

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════
    //  SELECTED INTERESTS
    // ═══════════════════════════════════════════════

    match /selected_interests/{interest} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  DAILY WORDS
    // ═══════════════════════════════════════════════

    match /daily_words/{document} {
      // Public read so daily word loads before auth completes
      allow read: if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  GAME DATA  (Public read — question bank)
    // ═══════════════════════════════════════════════

    match /game_questions/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /game_achievements/{document} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                     && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
                     && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  LEADERBOARD  (Public read)
    // ═══════════════════════════════════════════════

    match /leaderboard/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  ADMIN NOTIFICATIONS
    // ═══════════════════════════════════════════════

    match /admin_notifications/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  FEEDBACK
    // ═══════════════════════════════════════════════

    match /feedback/{document} {
      allow read: if resource.data.userId == request.auth.uid || isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  USER-OWNED PROGRESS COLLECTIONS
    //  Document ID = userId
    // ═══════════════════════════════════════════════

    match /progress/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /game_progress/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /game_levels/{document} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /game_statistics/{document} {
      allow read, write: if isAuthenticated();
    }

    match /game_statistics_meta/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /study_plan/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /mock_test_progress/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════
    //  ADMIN-ONLY CONTENT COLLECTIONS
    //  Managed through the admin panel
    // ═══════════════════════════════════════════════

    match /content_vocabulary_chapters/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /content_vocabulary_words/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /content_grammar_chapters/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  VOCABULARY  — app query
    // ═══════════════════════════════════════════════

    match /vocabulary/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  CONFIG / APP SETTINGS  — app reads on startup
    // ═══════════════════════════════════════════════

    match /Config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  HOMEWORK  (Admin only)
    // ═══════════════════════════════════════════════

    match /homework/{homeworkId} {
      allow read, write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  ★ NEW: ADMIN API KEYS
    //  Structure: admin_api_keys/{keyId}
    //  All users read, only admin write
    // ═══════════════════════════════════════════════

    match /admin_api_keys/{keyId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  ★ NEW: API ERROR LOGS
    //  Structure: api_error_logs/{logId}
    //  Authenticated users can write (report errors)
    //  Admin can read
    // ═══════════════════════════════════════════════

    match /api_error_logs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  ★ NEW: ADMIN NOTIFICATION TARGETS
    //  Structure: admin_notification_targets/{targetId}
    // ═══════════════════════════════════════════════

    match /admin_notification_targets/{targetId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  DAILY QUIZ LEADERBOARD
    //  Structure: daily_quiz_leaderboard/{date}/entries/{userId}
    // ═══════════════════════════════════════════════

    match /daily_quiz_leaderboard/{date}/entries/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  DENY ALL OTHER COLLECTIONS
    // ═══════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
