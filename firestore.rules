rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ═══════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasUserIdField() {
      return resource.data.userId == request.auth.uid;
    }

    // ═══════════════════════════════════════════════
    //  USERS
    //  Document ID = userId
    // ═══════════════════════════════════════════════

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  CONFIG / APP SETTINGS (Public read)
    // ═══════════════════════════════════════════════

    // Uppercase C — used by remote_config_service & admin_repository
    match /Config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Lowercase fallback
    match /config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // App-level config (e.g. daily_word_config)
    match /app_config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  CONTENT COLLECTIONS  (Public read, admin write)
    //  Curriculum data: vocabulary, grammar, lessons, quizzes
    // ═══════════════════════════════════════════════

    match /vocabulary/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /lessons/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /quizzes/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /daily_words/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  GAME DATA  (Public read — question bank)
    // ═══════════════════════════════════════════════

    match /game_questions/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /game_achievements/{document} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                     && document.startsWith(request.auth.uid);
      allow update: if isAuthenticated()
                     && document.startsWith(request.auth.uid);
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  LEADERBOARD  (Public read)
    // ═══════════════════════════════════════════════

    match /leaderboard/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  ADMIN NOTIFICATIONS
    // ═══════════════════════════════════════════════

    match /admin_notifications/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  FEEDBACK
    // ═══════════════════════════════════════════════

    match /feedback/{document} {
      allow read: if resource.data.userId == request.auth.uid || isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  USER-OWNED PROGRESS COLLECTIONS
    //  Document ID = userId
    // ═══════════════════════════════════════════════

    match /progress/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /game_progress/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /game_levels/{document} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /game_statistics/{document} {
      allow read, write: if isAuthenticated();
    }

    match /game_statistics_meta/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /study_plan/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /mock_test_progress/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════
    //  ADMIN-ONLY CONTENT COLLECTIONS
    //  Managed through the admin panel
    // ═══════════════════════════════════════════════

    match /content_vocabulary_chapters/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /content_vocabulary_words/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /content_grammar_chapters/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  DAILY QUIZ LEADERBOARD
    //  Structure: daily_quiz_leaderboard/{date}/entries/{userId}
    // ═══════════════════════════════════════════════

    match /daily_quiz_leaderboard/{date}/entries/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  DENY ALL OTHER COLLECTIONS
    // ═══════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
