rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ═══════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasUserIdField(data) {
      return data.userId == request.auth.uid;
    }

    // ═══════════════════════════════════════════════
    //  USER COLLECTION
    //  Document ID = userId
    // ═══════════════════════════════════════════════

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  PROGRESS COLLECTION
    //  Document ID = userId
    // ═══════════════════════════════════════════════

    match /progress/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // ═══════════════════════════════════════════════
    //  GAME PROGRESS
    //  Document ID = userId
    // ═══════════════════════════════════════════════

    match /game_progress/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════
    //  GAME STATISTICS
    //  Has userId field (not document ID)
    // ═══════════════════════════════════════════════

    match /game_statistics/{document} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════
    //  GAME STATISTICS META
    //  Document ID = userId
    // ═══════════════════════════════════════════════

    match /game_statistics_meta/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════
    //  GAME ACHIEVEMENTS
    //  Has userId field (queried by where userId == ...)
    // ═══════════════════════════════════════════════

    match /game_achievements/{document} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════
    //  GAME LEVELS
    //  Has userId field (queried by where userId == ...)
    // ═══════════════════════════════════════════════

    match /game_levels/{document} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // ═══════════════════════════════════════════════
    //  GAME QUESTIONS
    //  Read-only content for all authenticated users
    // ═══════════════════════════════════════════════

    match /game_questions/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  LEADERBOARD
    // ═══════════════════════════════════════════════

    match /leaderboard/{document} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ═══════════════════════════════════════════════
    //  CONTENT COLLECTIONS (Read-only for all authenticated users)
    // ═══════════════════════════════════════════════

    match /content_vocabulary_chapters/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /content_vocabulary_words/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /content_grammar_chapters/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  VOCABULARY
    //  General vocabulary list
    // ═══════════════════════════════════════════════

    match /vocabulary/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  LESSONS
    //  Lesson content
    // ═══════════════════════════════════════════════

    match /lessons/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  QUIZZES
    //  Quiz content
    // ═══════════════════════════════════════════════

    match /quizzes/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  STUDY PLAN
    //  Document ID = userId
    // ═══════════════════════════════════════════════

    match /study_plan/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // ═══════════════════════════════════════════════
    //  CONFIG / APP CONFIG (Public read)
    // ═══════════════════════════════════════════════

    match /config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /app_config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  ADMIN NOTIFICATIONS
    // ═══════════════════════════════════════════════

    match /admin_notifications/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  FEEDBACK
    // ═══════════════════════════════════════════════

    match /feedback/{document} {
      allow read: if request.resource.data.userId == request.auth.uid || isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    //  DENY ALL OTHER COLLECTIONS
    // ═══════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
